# Copy to .env and edit before running `docker compose up -d`

# Run `id` on the host to get these — should match the user that owns MEDIA_ROOT
PUID=1000
PGID=1000

TZ=Asia/Colombo

# Root directory on the host where media + downloads live (USB SSD, NVMe, etc.)
# Must contain: movies/, tv/, music/, books/, downloads/
MEDIA_ROOT=/mnt/media

# 64-char hex string for Homarr's encrypted settings store.
# Generate with: openssl rand -hex 32
HOMARR_SECRET=replace_me_with_openssl_rand_hex_32
